# OpenRouter — ALL model calls route through OpenRouter (OpenAI-compatible).
# Get a key: https://openrouter.ai/keys
# NEVER commit the real key — .env is gitignored (CLAUDE.md guardrail).
OPENROUTER_API_KEY=''
HF_TOKEN=''
# Weights & Biases — every run logs config + scalars + a full-CoT table (SPEC_phase2 §1).
WANDB_API_KEY=''
WANDB_ENTITY=''            # team/org slug; blank => your key's default (personal) entity
# Optional — override the W&B project (default: cot-monitorability).
# WANDB_PROJECT=cot-monitorability
# Optional — Inspect log directory (default ./logs; gitignored).
# INSPECT_LOG_DIR=./logs
